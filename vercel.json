{
  "version": 2,
  "installCommand": "cd admin-web && npm ci",
  "buildCommand": "cd admin-web && npm run build",
  "outputDirectory": "admin-web/build",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
