{
  "version": 2,
  "installCommand": "cd admin-web && npm ci",
  "buildCommand": "cd admin-web && npm run build",
  "outputDirectory": "admin-web/build",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://oxford-mileage-backend.onrender.com",
    "REACT_APP_WEB_URL": "https://expense.oxfordhouse.org"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096",
      "REACT_APP_API_URL": "https://oxford-mileage-backend.onrender.com",
      "REACT_APP_WEB_URL": "https://expense.oxfordhouse.org"
    }
  }
}
