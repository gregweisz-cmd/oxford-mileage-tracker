# Optional: Public web portal URL (used in emails, OAuth redirects when FRONTEND_URL is unset)
# Production: https://expense.oxfordhouse.org
# ADMIN_PORTAL_URL=https://expense.oxfordhouse.org
# WEB_PORTAL_URL=https://expense.oxfordhouse.org
# FRONTEND_URL=https://expense.oxfordhouse.org

# Google OAuth (staff portal "Continue with Google" + mobile)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=https://oxford-mileage-backend.onrender.com/api/auth/google/callback
# API_BASE_URL=https://oxford-mileage-backend.onrender.com
# ALLOWED_EMAIL_DOMAINS=oxfordhouse.org,example.org
# AUTO_CREATE_ACCOUNTS=false

# Optional: HR / External Employee API (for "Sync from HR API" in Admin Portal)
# Get the token from your Director of Tech for https://api.appwarmer.com/api/employee
# EMPLOYEE_API_TOKEN=your_token_here
# Or use: APPWARMER_EMPLOYEE_API_TOKEN=your_token_here

# Optional: Server
# PORT=3003

# Optional: Database path (default: expense_tracker.db in this directory)
# On Render with a persistent disk, use: DATABASE_PATH=/data/expense_tracker.db
# DATABASE_PATH=./expense_tracker.db

# Optional: Upload directory for receipts/signatures (default: uploads in this directory)
# On Render with a persistent disk, use: UPLOAD_DIR=/data/uploads
# UPLOAD_DIR=./uploads

# Optional: Database backup configuration
# By default the backup job writes nightly snapshots to <dir of DATABASE_PATH>/backups
# Override the directory or trigger time as needed. See docs/BACKUPS_AND_UPTIME.md.
# BACKUP_DIR=/data/backups
# BACKUP_HOUR=2
# BACKUP_DISABLED=1   # set to 1 to disable the scheduled job entirely
